---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArticleGrid from '../components/ArticleGrid.tsx';

export function getStaticPaths() {
  return [
    { params: { category: 'architecture' } },
    { params: { category: 'construction' } },
  ];
}

const { category } = Astro.params;
const pageTitle = category!.charAt(0).toUpperCase() + category!.slice(1);
---

<Layout title={`${pageTitle} - WFA & Partners`} description={`Projets de ${category} par WFA & Partners`}>
  <Header />

  <section class="pt-24 pb-24 bg-gray-900 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ArticleGrid client:load category={category as 'architecture' | 'construction'} showTitle={true} />
    </div>
  </section>

  <Footer />
</Layout>
