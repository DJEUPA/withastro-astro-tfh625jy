---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Carousel from '../components/Carousel.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { supabase } from '../lib/supabase';
import type { Article } from '../lib/types';

const { data: articles } = await supabase
  .from('articles')
  .select('*')
  .eq('published', true)
  .order('created_at', { ascending: false })
  .limit(6);

const recentArticles = (articles || []) as Article[];
---

<Layout title="WFA & Partners - Architecture & Construction">
  <Header />
  <Carousel />

  <section class="py-24 bg-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-white mb-4">Bienvenue chez WFA & Partners</h2>
        <p class="text-gray-400 text-lg max-w-2xl mx-auto">
          Cabinet d'architecture et de construction spécialisé dans la conception
          de bâtiments contemporains et durables.
        </p>
      </div>

      {recentArticles.length > 0 && (
        <div>
          <h2 class="text-2xl font-bold text-white mb-8">Projets récents</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {recentArticles.map((article) => (
              <ArticleCard article={article} />
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <Footer />
</Layout>
