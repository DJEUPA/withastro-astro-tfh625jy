---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { supabase } from '../../lib/supabase';
import { getArticleImages } from '../../lib/types';
import type { Article } from '../../lib/types';

const { id } = Astro.params;

const { data: article } = await supabase
  .from('articles')
  .select('*')
  .eq('id', id)
  .maybeSingle();

if (!article) {
  return Astro.redirect('/404');
}

const articleData = article as Article;
const images = getArticleImages(articleData);
---

<Layout title={`${articleData.title} - WFA & Partners`} description={articleData.description || ''}>
  <Header />

  <article class="pt-24 pb-24 bg-gray-900 min-h-screen">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href={`/${articleData.category}`} class="inline-flex items-center text-blue-400 hover:text-blue-300 mb-6 mt-8 text-sm">
        <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Retour
      </a>

      <div class="mb-6">
        <span class="inline-block bg-blue-600 text-white text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full">
          {articleData.category}
        </span>
      </div>

      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">{articleData.title}</h1>

      {articleData.description && (
        <p class="text-xl text-gray-400 mb-8">{articleData.description}</p>
      )}

      {images.length > 0 && (
        <div class="mb-8">
          {images.length === 1 ? (
            <div class="rounded-2xl overflow-hidden bg-gray-800">
              <img
                src={images[0]}
                alt={articleData.title}
                class="w-full max-h-[600px] object-contain"
              />
            </div>
          ) : (
            <div class={`grid gap-3 ${images.length === 2 ? 'grid-cols-2' : images.length === 3 ? 'grid-cols-3' : 'grid-cols-2'}`}>
              {images.map((img, index) => (
                <div class="rounded-xl overflow-hidden bg-gray-800 aspect-video">
                  <img
                    src={img}
                    alt={`${articleData.title} - photo ${index + 1}`}
                    class="w-full h-full object-contain"
                  />
                </div>
              ))}
            </div>
          )}
        </div>
      )}

      {articleData.content && (
        <p class="text-gray-300 text-lg leading-relaxed whitespace-pre-wrap">{articleData.content}</p>
      )}
    </div>
  </article>

  <Footer />
</Layout>
