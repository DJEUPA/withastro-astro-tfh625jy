---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page non trouvée - WFA & Partners">
  <div class="min-h-screen flex items-center justify-center bg-gray-900">
    <div class="text-center">
      <h1 class="text-6xl font-bold text-white mb-4">404</h1>
      <p class="text-gray-400 text-xl mb-8">Cette page n'existe pas.</p>
      <a href="/" class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-3 rounded-lg transition-colors">
        Retour à l'accueil
      </a>
    </div>
  </div>
</Layout>
