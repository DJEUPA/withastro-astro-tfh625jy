---
import Layout from '../../../../layouts/Layout.astro';
import { verifyAdminAuth } from '../../../../lib/auth';
import { createClient } from '@supabase/supabase-js';

const supabaseUrl = import.meta.env.VITE_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.VITE_SUPABASE_ANON_KEY;

const user = await verifyAdminAuth(Astro.cookies);
if (!user) {
  return Astro.redirect('/admin/login');
}

const { id } = Astro.params;
const accessToken = Astro.cookies.get('sb_access_token')?.value;
const supabase = createClient(supabaseUrl, supabaseAnonKey, {
  global: {
    headers: {
      Authorization: `Bearer ${accessToken}`,
    },
  },
});

const { data: article } = await supabase
  .from('articles')
  .select('*')
  .eq('id', id)
  .maybeSingle();

if (!article) {
  return Astro.redirect('/admin/articles');
}
---

<Layout title={`Modifier: ${article.title} - WFA & Partners`}>
  <div class="min-h-screen bg-gray-900">
    <header class="bg-black border-b border-gray-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <div class="flex items-center">
            <a href="/admin/articles" class="text-gray-400 hover:text-white mr-4 text-sm">← Articles</a>
            <h1 class="text-xl font-bold text-white">Modifier l'article</h1>
          </div>
          <a href="/admin/logout" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg text-sm">
            Déconnexion
          </a>
        </div>
      </div>
    </header>

    <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <form id="articleForm" class="space-y-6">
        <div id="formError" class="hidden bg-red-900/50 border border-red-500 text-red-200 px-4 py-3 rounded-lg"></div>

        <input type="hidden" id="articleId" value={article.id} />
        <input type="hidden" id="currentImageUrl" value={article.image_url} />

        <div>
          <label for="title" class="block text-sm font-medium text-gray-300 mb-2">Titre *</label>
          <input
            type="text"
            id="title"
            name="title"
            required
            value={article.title}
            class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          />
        </div>

        <div>
          <label for="description" class="block text-sm font-medium text-gray-300 mb-2">Description courte *</label>
          <textarea
            id="description"
            name="description"
            rows="3"
            required
            class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          >{article.description}</textarea>
        </div>

        <div>
          <label for="content" class="block text-sm font-medium text-gray-300 mb-2">Contenu complet *</label>
          <textarea
            id="content"
            name="content"
            rows="10"
            required
            class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          >{article.content}</textarea>
        </div>

        <div>
          <label for="category" class="block text-sm font-medium text-gray-300 mb-2">Catégorie *</label>
          <select
            id="category"
            name="category"
            required
            class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          >
            <option value="architecture" selected={article.category === 'architecture'}>Architecture</option>
            <option value="construction" selected={article.category === 'construction'}>Construction</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Image actuelle</label>
          <img src={article.image_url} alt={article.title} class="w-64 h-40 object-cover rounded-lg border border-gray-700 mb-4" />

          <label for="image" class="block text-sm font-medium text-gray-300 mb-2">Changer l'image (optionnel)</label>
          <div class="flex items-center space-x-4">
            <input
              type="file"
              id="image"
              name="image"
              accept="image/*"
              class="hidden"
            />
            <button
              type="button"
              id="imageBtn"
              class="px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg text-sm"
            >
              Choisir une nouvelle image
            </button>
            <span id="imageFileName" class="text-gray-400 text-sm">Garder l'image actuelle</span>
          </div>
          <div id="imagePreview" class="hidden mt-4">
            <img id="previewImg" class="w-64 h-40 object-cover rounded-lg border border-gray-700" />
          </div>
        </div>

        <div class="flex items-center">
          <input
            type="checkbox"
            id="published"
            name="published"
            checked={article.published}
            class="w-4 h-4 text-blue-600 bg-gray-800 border-gray-600 rounded focus:ring-blue-500"
          />
          <label for="published" class="ml-2 text-sm text-gray-300">Publié</label>
        </div>

        <div class="flex space-x-4">
          <button
            type="submit"
            id="submitBtn"
            class="px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium transition-colors"
          >
            Enregistrer les modifications
          </button>
          <a href="/admin/articles" class="px-6 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg font-medium transition-colors">
            Annuler
          </a>
        </div>
      </form>
    </main>
  </div>

  <script is:inline define:vars={{ supabaseUrl, anonKey: supabaseAnonKey }}>
    const fileInput = document.getElementById('image');
    const imageBtn = document.getElementById('imageBtn');
    const imageFileName = document.getElementById('imageFileName');
    const imagePreview = document.getElementById('imagePreview');
    const previewImg = document.getElementById('previewImg');

    imageBtn.addEventListener('click', () => fileInput.click());

    fileInput.addEventListener('change', () => {
      const file = fileInput.files[0];
      if (file) {
        imageFileName.textContent = file.name;
        previewImg.src = URL.createObjectURL(file);
        imagePreview.classList.remove('hidden');
      }
    });

    document.getElementById('articleForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = document.getElementById('submitBtn');
      const formError = document.getElementById('formError');
      formError.classList.add('hidden');

      submitBtn.disabled = true;
      submitBtn.textContent = 'Enregistrement...';

      try {
        const token = document.cookie
          .split('; ')
          .find(c => c.startsWith('sb_access_token='))
          ?.split('=')[1];

        const articleId = document.getElementById('articleId').value;
        let imageUrl = document.getElementById('currentImageUrl').value;

        const file = fileInput.files[0];
        if (file) {
          const fileExt = file.name.split('.').pop();
          const fileName = `${Date.now()}.${fileExt}`;
          const filePath = fileName;

          const uploadRes = await fetch(`${supabaseUrl}/storage/v1/object/article-images/${filePath}`, {
            method: 'POST',
            headers: {
              'Authorization': `Bearer ${token}`,
              'Content-Type': file.type,
            },
            body: file,
          });

          if (!uploadRes.ok) {
            throw new Error('Erreur lors de l\'upload de l\'image');
          }

          imageUrl = `${supabaseUrl}/storage/v1/object/public/article-images/${filePath}`;
        }

        const articleData = {
          title: document.getElementById('title').value,
          description: document.getElementById('description').value,
          content: document.getElementById('content').value,
          category: document.getElementById('category').value,
          image_url: imageUrl,
          published: document.getElementById('published').checked,
        };

        const res = await fetch(`${supabaseUrl}/rest/v1/articles?id=eq.${articleId}`, {
          method: 'PATCH',
          headers: {
            'apikey': anonKey,
            'Authorization': `Bearer ${token}`,
            'Content-Type': 'application/json',
            'Prefer': 'return=minimal',
          },
          body: JSON.stringify(articleData),
        });

        if (res.ok) {
          window.location.href = '/admin/articles';
        } else {
          const err = await res.json();
          throw new Error(err.message || 'Erreur lors de la modification');
        }
      } catch (error) {
        formError.classList.remove('hidden');
        formError.textContent = error.message || 'Erreur lors de la modification';
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Enregistrer les modifications';
      }
    });
  </script>
</Layout>
